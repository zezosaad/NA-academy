{
  "expo": {
    "name": "NA-Academy",
    "slug": "NA-Academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/NA-icon.png",
    "scheme": "naacademy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091220",
        "foregroundImage": "./assets/images/NA-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.abanoubabdelmessih.NAAcademy"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/NA-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/NA-splash-calm.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}