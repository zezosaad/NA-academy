  "info": {
    "title": "NA-Academy API",
    "description": "NA-Academy Backend Platform API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "student@example.com"
          },
          "password": {
            "type": "string",
            "example": "securePass123",
            "minLength": 6
          },
          "name": {
            "type": "string",
            "example": "Ahmed Hassan"
          },
          "hardwareId": {
            "type": "string",
            "example": "device-fingerprint-string"
          }
        },
        "required": [
          "email",
          "password",
          "name",
          "hardwareId"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "student@example.com"
          },
          "password": {
            "type": "string",
            "example": "securePass123"
          },
          "hardwareId": {
            "type": "string",
            "example": "device-fingerprint-string"
          }
        },
        "required": [
          "email",
          "password",
          "hardwareId"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "UpdateStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suspended",
              "banned"
            ],
            "example": "suspended"
          }
        },
        "required": [
          "status"
        ]
      },
      "CreateSubjectDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Algebra I"
          },
          "description": {
            "type": "string",
            "example": "Introduction to algebraic concepts"
          },
          "category": {
            "type": "string",
            "example": "Mathematics"
          }
        },
        "required": [
          "title",
          "category"
        ]
      },
      "UpdateSubjectDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Algebra I"
          },
          "description": {
            "type": "string",
            "example": "Introduction to algebraic concepts"
          },
          "category": {
            "type": "string",
            "example": "Mathematics"
          }
        }
      },
      "CreateBundleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Science Bundle"
          },
          "subjectIds": {
            "example": [
              "507f1f77bcf86cd799439011"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "subjectIds"
        ]
      },
      "UpdateBundleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Science Bundle"
          },
          "subjectIds": {
            "example": [
              "507f1f77bcf86cd799439011"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "QuestionOptionDto": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "example": "A"
          },
          "text": {
            "type": "string",
            "example": "x = 1"
          }
        },
        "required": [
          "label",
          "text"
        ]
      },
      "CreateQuestionDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "example": "Solve for x: 2x = 2"
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionOptionDto"
            }
          },
          "correctOption": {
            "type": "string",
            "example": "A"
          },
          "timeLimitSeconds": {
            "type": "number",
            "example": 60
          },
          "imageRef": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "order": {
            "type": "number",
            "example": 1
          }
        },
        "required": [
          "text",
          "options",
          "correctOption",
          "timeLimitSeconds",
          "order"
        ]
      },
      "CreateExamDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Algebra Midterm"
          },
          "subjectId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "hasFreeSection": {
            "type": "boolean",
            "example": false
          },
          "freeQuestionCount": {
            "type": "number",
            "example": 0
          },
          "freeAttemptLimit": {
            "type": "number",
            "example": 0
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateQuestionDto"
            }
          }
        },
        "required": [
          "title",
          "subjectId",
          "questions"
        ]
      },
      "AnswerDto": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "selectedOption": {
            "type": "string",
            "example": "A"
          }
        },
        "required": [
          "questionId",
          "selectedOption"
        ]
      },
      "SubmitExamDto": {
        "type": "object",
        "properties": {
          "examSessionId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439015"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnswerDto"
            }
          }
        },
        "required": [
          "examSessionId",
          "answers"
        ]
      },
      "UpdateExamDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Algebra Midterm"
          },
          "subjectId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "hasFreeSection": {
            "type": "boolean",
            "example": false
          },
          "freeQuestionCount": {
            "type": "number",
            "example": 0
          },
          "freeAttemptLimit": {
            "type": "number",
            "example": 0
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateQuestionDto"
            }
          }
        }
      },
      "GenerateSubjectCodesDto": {
        "type": "object",
        "properties": {
          "subjectId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "bundleId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439012"
          },
          "quantity": {
            "type": "number",
            "example": 500
          }
        },
        "required": [
          "quantity"
        ]
      },
      "GenerateExamCodesDto": {
        "type": "object",
        "properties": {
          "examId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "quantity": {
            "type": "number",
            "example": 200
          },
          "usageType": {
            "type": "string",
            "enum": [
              "single",
              "multi"
            ]
          },
          "maxUses": {
            "type": "number",
            "example": 5
          },
          "timeLimitMinutes": {
            "type": "number",
            "example": 1440
          }
        },
        "required": [
          "examId",
          "quantity",
          "usageType"
        ]
      },
      "ActivateCodeDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "KR7NV3PXHM4T"
          }
        },
        "required": [
          "code"
        ]
      },
      "ReportFlagDto": {
        "type": "object",
        "properties": {
          "flagType": {
            "type": "string",
            "enum": [
              "screen_recording",
              "root_jailbreak",
              "vpn_proxy",
              "suspicious_activity"
            ]
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "flagType"
        ]
      },
      "ReviewFlagDto": {
        "type": "object",
        "properties": {
          "actionTaken": {
            "type": "string",
            "enum": [
              "none",
              "session_terminated",
              "account_suspended",
              "warning_issued"
            ]
          }
        },
        "required": [
          "actionTaken"
        ]
      },
      "TrackWatchTimeDto": {
        "type": "object",
        "properties": {
          "mediaAssetId": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011"
          },
          "durationSeconds": {
            "type": "number",
            "example": 120
          }
        },
        "required": [
          "mediaAssetId",
          "durationSeconds"
        ]
      }
    }
  }
}